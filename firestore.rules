rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to get user role (Claims > Doc)
    function getUserRole() {
      return request.auth.token.role != null ? request.auth.token.role : getUserData().role;
    }

    // Helper to get schoolId (Claims > Doc schoolId > Doc uai)
    function getSchoolId() {
      return request.auth.token.schoolId != null 
        ? request.auth.token.schoolId 
        : (getUserData().schoolId != null ? getUserData().schoolId : getUserData().uai);
    }

    // Helper to check if School Head
    function isSchoolHead() {
      return getUserRole() == 'school_head';
    }

    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to get user data (Legacy)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper to check Super Admin
    function isSuperAdmin() {
      return request.auth.token.email == 'pledgeum@gmail.com';
    }

    // Users: Owners OR School Heads of the same school (for Imports/Management)
    match /users/{userId} {
      allow create: if isOwner(userId) || (isSchoolHead() && (request.resource.data.schoolId == getSchoolId() || request.resource.data.uai == getSchoolId()));
      allow read, update, delete: if isOwner(userId) || (isSchoolHead() && (resource.data.schoolId == getSchoolId() || resource.data.uai == getSchoolId())) || isSuperAdmin();
    }

    // Conventions: Strict Data Isolation
    match /conventions/{conventionId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && (
        isSuperAdmin()
        || resource.data.userId == request.auth.uid
        // Participants access via Email matching
        || resource.data.studentId == request.auth.token.email
        || resource.data.prof_email == request.auth.token.email
        || resource.data.rep_legal_email == request.auth.token.email
        || resource.data.tuteur_email == request.auth.token.email
        || resource.data.ent_rep_email == request.auth.token.email
        || resource.data.ecole_chef_email == request.auth.token.email
        // School-wide access for Head/Admin
        || resource.data.schoolId == getSchoolId()
        || resource.data.uai == getSchoolId()
      );
    }

    // Notifications: Recipient Only for Read/Update
    match /notifications/{notificationId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && resource.data.recipientEmail == request.auth.token.email;
    }

    // Evaluation Templates: Read for Authenticated, Write for Admin
    match /evaluation_templates/{templateId} {
        allow read: if isAuthenticated();
        // Allow write only for SuperAdmin or maybe SchoolHead? For now read is the blocker.
        allow write: if isSuperAdmin(); 
    }

    // Mission Orders: Authenticated users only (Improve this later)
    match /missionOrders/{orderId} {
      allow read, write: if isAuthenticated();
    }

    // Alumni: Authenticated users only
    match /alumni/{alumniId} {
      allow read, write: if isAuthenticated();
    }

    // OTPs: Deny All (Server-side Admin SDK only)
    match /otps/{otpId} {
        allow read, write: if false;
    }

    // Invitations: Authenticated users can create (send) invitations
    // Verification is done via Server-side Admin SDK
    match /invitations/{invitationId} {
        allow read, write: if isAuthenticated();
    }

    // Rate Limits: Deny All (Server-side Admin SDK only)
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    // Default Organization / Sandbox: Allow public read for authenticated users
    match /establishments/9999999X {
        allow read: if isAuthenticated();
        allow write: if isSuperAdmin(); 
        
        // Allow recursive access to subcollections (classes, students, teachers)
        match /{document=**} {
             allow read: if isAuthenticated();
             allow write: if isSuperAdmin() || (isSchoolHead() && getSchoolId() == '9999999X');
        }
    }
    
    // Companies: Allow read for all, write for authenticated (Refine later)
    match /companies/{companyId} {
        allow read, write: if isAuthenticated();
    }
  }
}
